# ── تنظیمات سرور دفتر حساب ──
# این فایل را کپی کن به نام .env و مقادیر را پر کن

# رشته اتصال PostgreSQL
# محلی:  postgresql://postgres:PASSWORD@localhost:5432/ledger
# روی هاست (Railway/Render/Neon) این مقدار را خودشان می‌دهند:
DATABASE_URL=postgresql://postgres:password@localhost:5432/ledger

# اگر دیتابیس ابری SSL می‌خواهد این را true کن (Neon/Render/Railway معمولاً true)
PGSSL=false

# کلید امضای توکن — یک رشته تصادفی طولانی بگذار (مثلاً خروجی دستور زیر):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# پورت سرور
PORT=3000

# دامنه‌هایی که اجازه دسترسی دارند (اپ فرانت). برای تست: *
# در پروداکشن دامنه واقعی: https://your-site.com
CORS_ORIGIN=*
